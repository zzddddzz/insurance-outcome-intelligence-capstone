<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.dizhang.cloudflared-tunnel</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/dizhang/.cloudflared/cloudflared</string>
    <string>--config</string>
    <string>/Users/dizhang/.cloudflared/config.yml</string>
    <string>tunnel</string>
    <string>run</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
