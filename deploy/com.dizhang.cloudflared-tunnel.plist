  <string>/Users/dizhang</string>
  <key>StandardOutPath</key>
  <string>/Users/dizhang/.cloudflared/logs/cloudflared.launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/dizhang/.cloudflared/logs/cloudflared.launchd.err.log</string>
</dict>
</plist>
